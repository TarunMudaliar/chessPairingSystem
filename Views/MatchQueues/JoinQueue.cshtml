@{
    ViewData["Title"] = "Join Queue";
}

<h2>Join Matchmaking Queue</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="JoinQueue" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Location</label>
        <select name="location" class="form-select" required>
            <option value="">-- Select Location --</option>
            <option value="Chess Club">Chess Club</option>
            <option value="Library">Library</option>
            <option value="Room 101">Room 101</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Scheduled Time</label>
        <select name="scheduledTime" class="form-select" required>
            <option value="">-- Select Time --</option>
            <option value="Lunchtime">Lunchtime</option>
            <option value="After School">After School</option>
            <option value="Morning Tea">Morning Tea</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Join Queue</button>
    <a asp-action="MyQueue" class="btn btn-secondary">View My Queue Status</a>
</form>