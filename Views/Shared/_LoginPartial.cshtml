@using Microsoft.AspNetCore.Identity
@using chessPairingSystem.Areas.Identity.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item px-2">
            <a id="manage" class="nav-link fw-bold custom-nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                Hello @UserManager.GetUserName(User)!
            </a>
        </li>
        <li class="nav-item px-2">
            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button id="logout" type="submit" class="btn btn-outline-light px-4 py-1 rounded-pill fw-bold btn-sm style="transition: all 0.2s;">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item px-2">
            <a class="nav-link fw-bold custom-nav-link" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item px-2">
            <a id="login" asp-area="Identity" asp-page="/Account/Login" class="btn btn-register-pill px-4 py-2 d-inline-block">
                Login
            </a>
        </li>
    }
</ul>