@using Microsoft.AspNetCore.Identity
@using chessPairingSystem.Areas.Identity.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        // Pull the database profile details for the currently active user
        var currentUser = await UserManager.GetUserAsync(User);
        var displayName = !string.IsNullOrWhiteSpace(currentUser?.PlayerName) ? currentUser.PlayerName : UserManager.GetUserName(User);

        <li class="nav-item px-2">
            <a id="manage" class="nav-link fw-bold custom-nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                Hello @displayName!
            </a>
        </li>
        <li class="nav-item px-2">
            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button id="logout" type="submit" class="nav-link btn btn-link fw-bold custom-nav-link" style="border: none; background: none;">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item px-2">
            <a class="nav-link fw-bold custom-nav-link" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item px-2">
            <a id="login" asp-area="Identity" asp-page="/Account/Login" class="nav-link fw-bold custom-nav-link">
                Login
            </a>
        </li>
    }
</ul>