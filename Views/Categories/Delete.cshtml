@model chessPairingSystem.Areas.Identity.Data.ApplicationUser

@{
    ViewData["Title"] = "Remove Player";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">

            <div class="card p-4 p-sm-5 shadow-lg rounded-3 border-danger" style="background-color: #1e1e1e !important; border: 1px solid #dc3545 !important;">

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-danger font-komika text-uppercase" style="letter-spacing: 1px;">Remove Player?</h2>
                    <p class="text-muted small">Are you sure you want to permanently delete this user account?</p>
                </div>

                <div class="p-3 mb-4 rounded-2" style="background-color: #151515;">
                    <div class="mb-2">
                        <span class="text-muted small d-block">Player Name:</span>
                        <span class="text-white fw-bold">@(Model.PlayerName ?? "Unnamed Player")</span>
                    </div>
                    <div class="mb-2">
                        <span class="text-muted small d-block">Email Address:</span>
                        <span class="text-white font-monospace">@Model.Email</span>
                    </div>
                    <div>
                        <span class="text-muted small d-block">Division Assignment:</span>
                        <span class="badge bg-secondary">@(Model.Category?.CategoryName ?? "Unassigned")</span>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-50 fw-bold py-2">Cancel</a>
                        <button type="submit" class="btn btn-danger w-50 fw-bold py-2">Confirm Delete</button>
                    </div>
                </form>

            </div>

        </div>
    </div>
</div>