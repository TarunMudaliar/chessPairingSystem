@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url('/images/chess-bg.jpg') no-repeat center center fixed;
        background-size: cover;
        height: 100vh;
        overflow: hidden; /* Locks the page scroll entirely */
    }

    .home-hero-container {
        height: calc(100vh - 88px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .font-komika {
        font-family: 'Komika Hand', 'Comic Neue', 'Comic Sans MS', cursive, sans-serif;
        font-weight: bold;
    }

    .btn-register-pill {
        background-color: #ced4da;
        color: #212529;
        font-weight: 600;
        padding: 12px 45px;
        border-radius: 50px;
        transition: all 0.2s ease-in-out;
        text-decoration: none;
    }

        .btn-register-pill:hover {
            background-color: #ffffff;
            color: #000000;
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
        }
</style>

<div class="container-fluid home-hero-container text-center">
    <h1 class="display-1 mb-2 text-white font-komika" style="text-shadow: 2px 2px 10px rgba(0,0,0,0.8);">Welcome</h1>
    <p class="lead mb-5 text-white fs-3 fw-bold" style="max-width: 650px; text-shadow: 1px 1px 8px rgba(0,0,0,0.9);">
        Your journey through Avondale College Chess begins here.
    </p>

    @if (User.Identity?.IsAuthenticated != true)
    {
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-register-pill shadow-sm fs-5">Register</a>
    }
    else if (User.IsInRole("Player"))
    {
        <a asp-area="" asp-controller="MatchQueues" asp-action="JoinQueue" class="btn btn-light px-5 py-3 rounded-pill fw-bold fs-5 shadow">Enter Matchmaking Room →</a>
    }
    else if (User.IsInRole("Admin"))
    {
        <a asp-area="" asp-controller="Appeals" asp-action="Index" class="btn btn-primary px-5 py-3 rounded-pill fw-bold fs-5 shadow">Open Admin Dashboard →</a>
    }
</div>