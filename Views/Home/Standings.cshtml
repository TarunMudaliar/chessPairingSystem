@model IEnumerable<chessPairingSystem.Areas.Identity.Data.ApplicationUser>

@{
    ViewData["Title"] = "Tournament Standings";
    int rank = 1;
}

<div class="container mt-4">
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold text-dark">Leaderboard Standings</h1>
        <p class="text-muted fs-5">Live rankings for the Avondale College Chess</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark text-uppercase">
                    <tr>
                        <th scope="col" class="ps-4" style="width: 10%">Rank</th>
                        <th scope="col" style="width: 45%">Player Name</th>
                        <th scope="col" style="width: 25%">Year Level</th>
                        <th scope="col" class="text-end pe-4" style="width: 20%">Chess Rating</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="text-dark fw-bold">#@rank</span>
                            </td>

                            <td>
                                <span class="fw-semibold text-dark">@player.PlayerName</span>
                                <small class="text-muted d-block">@player.Email</small>
                            </td>

                            <td>
                                @(player.Category != null ? player.Category.CategoryName : "Unassigned")
                            </td>

                            <td class="text-end pe-4">
                                <span class="badge bg-light text-dark border border-secondary font-monospace fs-6 px-3 py-1.5">
                                    @player.Ratings
                                </span>
                            </td>
                        </tr>

                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>