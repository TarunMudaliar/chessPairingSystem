@model chessPairingSystem.Models.Appeal

@{
    ViewData["Title"] = "Submit Appeal";
}

<h1>Submit Appeal</h1>
<h4>Appeal Details</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="GameId" class="control-label">Select Disputed Match (Game ID)</label>
                <select asp-for="GameId" class="form-control" asp-items="ViewBag.GameId">
                    <option value="" selected disabled>-- Select Match --</option>
                </select>
                <span asp-validation-for="GameId" class="text-danger"></span>
            </div>

            <input type="hidden" asp-for="PlayerId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />
            <input type="hidden" asp-for="Status" value="Pending" />
            <input type="hidden" asp-for="SubmittedAt" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")" />

            <div class="form-group mb-3">
                <label asp-for="Message" class="control-label">Reason for Appeal</label>
                <textarea asp-for="Message" class="form-control" rows="5" placeholder="Describe what happened during the match..."></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Submit Dispute" class="btn btn-primary" />
                <a asp-action="MyAppeals" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}