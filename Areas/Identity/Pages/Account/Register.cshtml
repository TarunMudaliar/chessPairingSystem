@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">

            <div class="card p-4 p-sm-5 shadow-lg rounded-3" style="background-color: #1e1e1e !important; border: 1px solid #2d2d2d !important;">

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-white font-komika text-uppercase" style="letter-spacing: 1px;">Create Account</h2>
                    <p class="text-muted small">Join the Avondale College Chess Leaderboard</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.SelectedYearLevel" class="form-label fw-bold text-light small mb-2">Year Level</label>
                        <select asp-for="Input.SelectedYearLevel" class="form-control" style="height: 3rem;">
                            <option value="" disabled selected>-- Select your Year Level --</option>
                            <option value="1">Year 9</option>
                            <option value="2">Year 10</option>
                            <option value="3">Year 11</option>
                            <option value="4">Year 12</option>
                            <option value="5">Year 13</option>
                        </select>
                        <span asp-validation-for="Input.SelectedYearLevel" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold text-light small mb-2">Email Address</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" style="height: 3rem;" />
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.Password" class="form-label fw-bold text-light small mb-2">Password</label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Password" style="height: 3rem;" />
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-bold text-light small mb-2">Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm Password" style="height: 3rem;" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="w-100 btn btn-primary fw-bold py-2.5 rounded-2 tracking-wide text-uppercase" style="background-color: #0d6efd; border: none; transition: all 0.2s;">
                        Register
                    </button>
                </form>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}